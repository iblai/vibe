# ibl.ai Platform Configuration
NEXT_PUBLIC_API_BASE_URL={{ api_base_url }}
NEXT_PUBLIC_AUTH_URL={{ auth_url }}
NEXT_PUBLIC_BASE_WS_URL={{ ws_url }}
NEXT_PUBLIC_PLATFORM_BASE_DOMAIN={{ platform_base_domain }}

# App Configuration
NEXT_PUBLIC_MAIN_TENANT_KEY={{ platform_key }}
NEXT_PUBLIC_IBL_PLATFORM=agent
NEXT_PUBLIC_AGENT_URL=http://localhost:3000
{% if has_mentor_id %}
NEXT_PUBLIC_DEFAULT_AGENT_ID={{ mentor_id }}
{% endif %}
{% if iblai_api_key %}

# Platform API Key (server-side only)
IBLAI_API_KEY={{ iblai_api_key }}
{% endif %}

# Tauri (desktop/mobile builds only)
# NEXT_PUBLIC_TAURI_CUSTOM_SCHEME=your-app-scheme

# Support
NEXT_PUBLIC_SUPPORT_EMAIL=support@ibl.ai
