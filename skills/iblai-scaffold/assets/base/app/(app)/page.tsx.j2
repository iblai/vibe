"use client";
{% raw %}
import { useMemo } from "react";
import { useUsername } from "@/hooks/use-user";
import { redirectToAuthSpa } from "@/lib/utils";

export default function Home() {
  const username = useUsername();
  const email = useMemo(() => {
    if (typeof window === "undefined") return "";
    try {
      const raw = localStorage.getItem("userData");
      if (raw) return JSON.parse(raw).email ?? "";
    } catch { /* ignore */ }
    return "";
  }, []);

  return (
    <main className="flex min-h-screen flex-col items-center justify-center p-8">
      <div className="text-center">
        <h1 className="bg-gradient-to-r from-[#38A1E5] to-[#7284FF] text-transparent bg-clip-text font-bold text-4xl mb-2">
          Welcome{username ? `, ${username}` : ""}
        </h1>
        <p className="text-gray-600 text-sm mb-8">
          {username}{email ? ` (${email})` : ""}
        </p>
        <div className="flex gap-4 justify-center">
          <a
            href="https://docs.ibl.ai"
            target="_blank"
            rel="noopener noreferrer"
            className="inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium text-white"
            style={{ background: "linear-gradient(135deg, #2563EB 0%, #93C5FD 100%)" }}
          >
            Documentation
          </a>
          <button
            onClick={() => redirectToAuthSpa(undefined, undefined, true)}
            className="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
          >
            Logout
          </button>
        </div>
      </div>
      <div className="mt-16 w-full max-w-lg text-xs text-gray-400">
        <p className="text-center mb-3 font-medium text-gray-500">Components ready to use:</p>
        <div className="space-y-1.5 font-mono">
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'import { ChatWidget } from "@/components/iblai/chat-widget"'}</code></p>
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'import { IblaiProfileDropdown } from "@/components/iblai/profile-dropdown"'}</code></p>
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'import { IblaiNotificationBell } from "@/components/iblai/notification-bell"'}</code></p>
        </div>
        <div className="mt-4 space-y-1.5 font-mono">
          <p className="text-center mb-2 font-medium text-gray-500 font-sans">Usage:</p>
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'<ChatWidget mentorId="your-mentor-id" />'}</code></p>
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'<IblaiProfileDropdown />'}</code></p>
          <p><code className="bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">{'<IblaiNotificationBell />'}</code></p>
        </div>
      </div>
    </main>
  );
}
{% endraw %}
