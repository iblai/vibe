// OAuth provider URL patterns — intercepted and opened externally
const OAUTH_URL_PATTERNS: &[&str] = &[
    "accounts.google.com",
    "google.com/o/oauth",
    "googleapis.com/oauth",
    "google-oauth2",
    "/auth/login/google",
    "/login/google",
    "appleid.apple.com",
    "/auth/login/apple",
    "/login/apple",
];

fn is_oauth_url(url: &str) -> bool {
    OAUTH_URL_PATTERNS.iter().any(|pattern| url.contains(pattern))
}

